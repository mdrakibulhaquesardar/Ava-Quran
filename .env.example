# -----------------------------------------------------------------------------
# Ava Quran Backend — copy to ".env" and adjust (never commit real secrets).
# -----------------------------------------------------------------------------

PORT=3000

# Swagger UI at /docs when enabled (off in production unless set to "true")
SWAGGER_ENABLED=true

# PostgreSQL (matches docker-compose defaults when using Compose Postgres)
DATABASE_URL=postgresql://ava:ava@localhost:5432/ava_quran?schema=public

# Redis: full URL preferred in Docker; host/port optional for local tooling
REDIS_URL=redis://localhost:6379

# Alternative if REDIS_URL is unset:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# JWT (add when auth module is implemented)
JWT_SECRET=change-me-in-production

# Quran.Foundation OAuth (placeholders)
QURAN_CLIENT_ID=
QURAN_CLIENT_SECRET=

# Google Gemini (placeholder)
GROQ_API_KEY=
